{
  "manifest_version": 3,
  "name": "URL Cookie Inspector",
  "version": "0.1.0",
  "description": "Read the active tab URL and cookies in Microsoft Edge.",
  "permissions": [
    "activeTab",
    "tabs",
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "URL Cookie Inspector",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
